{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/ecoreal/agentic-risk-scan/main/docs/config.schema.json",
  "title": "Agentic Risk Scan configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "fail_on": {
      "enum": ["critical", "high", "medium", "low", "info", "none"]
    },
    "baseline": {
      "type": "string"
    },
    "exclude": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "disabled_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "severity_overrides": {
      "type": "object",
      "additionalProperties": {
        "enum": ["critical", "high", "medium", "low", "info"]
      }
    },
    "suppressions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "fingerprint": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    }
  }
}
